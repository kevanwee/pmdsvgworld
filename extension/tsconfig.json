{
  "compilerOptions": {
    "module":            "commonjs",
    "target":            "ES2020",
    "outDir":            "./dist",
    "rootDir":           "./src",
    "strict":            true,
    "esModuleInterop":   true,
    "skipLibCheck":      true,
    "declaration":       false,
    "sourceMap":         true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
